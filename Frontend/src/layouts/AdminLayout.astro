---
const currentPath = Astro.url.pathname;

import "../styles/global.css"
const navItems = [
  { href: "/admin/dashboard", label: "Dashboard", icon: "grid" },
  { href: "/admin/products",     label: "Products", icon: "wrench" },
  { href: "/admin/rentals",   label: "Penyewaan", icon: "calendar" },
  { href: "/admin/users",     label: "Users", icon: "users" },
];
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BengkelRent Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>
<body class="bg-gray-950 text-white min-h-screen flex">

  <!-- SIDEBAR -->
  <aside class="w-56 min-h-screen shrink-0 bg-gray-900 border-r border-gray-800 flex flex-col p-4 gap-1">

    <!-- BRAND -->
    <div class="flex items-center gap-2 px-3 py-4 mb-4">
      <div class="w-8 h-8 rounded-xl bg-orange-500 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <p class="text-white font-bold text-sm leading-none">BengkelRent</p>
        <p class="text-orange-400 text-xs">Admin Panel</p>
      </div>
    </div>

    <!-- NAV -->
    <nav class="flex flex-col gap-1 flex-1">
      {navItems.map((item) => {
        const isActive = currentPath.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition duration-200 ${
              isActive
                ? "bg-orange-500 text-white shadow-md shadow-orange-500/20"
                : "text-gray-400 hover:bg-gray-800 hover:text-white"
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- FOOTER -->
    <div class="border-t border-gray-800 pt-4 mt-4">
      <div class="flex items-center gap-3 px-3">
        <div class="w-8 h-8 rounded-xl bg-orange-500/20 flex items-center justify-center shrink-0">
          <span class="text-orange-400 text-xs font-bold">AD</span>
        </div>
        <div>
          <p class="text-white text-xs font-medium">Admin</p>
          <p class="text-gray-500 text-xs">admin@bengkel.id</p>
        </div>
      </div>
    </div>

  </aside>

  <!-- MAIN -->
  <main class="flex-1 min-w-0 p-6 overflow-auto">
    <slot />
  </main>

</body>
</html>
