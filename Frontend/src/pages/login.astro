---
import "../styles/global.css"
---

<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title></title>
  </head>
  <body class="min-h-screen flex justify-center items-center">
    <div class="w-full max-w-sm bg-red p-8 rounded-xl shadow-lg text-center flex flex-col card my-8 gap-6">
      <h1 class="text-3xl ">Login</h1>
      <input class="input" autocomplete="off" type="text" id="username" placeholder="Username">
      <input class="input" type="password" id="password" placeholder="Password">
      <p class="disable text-accent" id="status">Status</p>
      <button class="rounded-xl btn-outline" id="loginbtn">Login</button>
    </div>
  </body>
<script>
  const login = document.getElementById("loginbtn");

  login.addEventListener("click", async () => {
    const name = document.getElementById("username").value;
    const password = document.getElementById("password").value;
    const status_info = document.getElementById("status");
    if(!name || !password){
      status_info.classList.remove("disable");
      status_info.textContent = "Please Fill Required Field";
      return;
    }
    status_info.classList.remove("disable");
    status_info.textContent = "Logging in..";
    try{
     const response = await fetch(`${import.meta.env.PUBLIC_BACKEND}/api/v1/auth/login`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        name,
        password,
      }),
    }
    );
    if(!response.ok){
      status_info.textContent = data.message || "Login Failed";
      return;
    }
    const data = await response.json();
    localStorage.setItem("token",data.token);
    status_info.textContent = "Login Successful";
      setTimeout(()=>{
        window.location.href = "/admin/dashboard";
      },2000);
    }catch(error){
      console.error(error);
      status_info.textContent ="Username Or Password Wrong";
    }

  });
</script>
</html>
