---
const currentPath = Astro.url.pathname;
import "../styles/global.css";

const navItems = [
  { href: "/admin/dashboard",    label: "dashboard",    cmd: "F1" },
  { href: "/admin/profile",      label: "profile",      cmd: "F2" },
  { href: "/admin/skills",       label: "skills",       cmd: "F3" },
  { href: "/admin/projects",     label: "projects",     cmd: "F4" },
  { href: "/admin/achievements", label: "achievements", cmd: "F5" },
];
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>portfolio.admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet" />
</head>
<body class="tui-root">

  <!-- TOPBAR -->
  <header class="tui-topbar">
    <span class="tui-topbar-brand">portfolio.exe</span>
    <span class="tui-topbar-sep">|</span>
    <span class="tui-topbar-path">{currentPath}</span>
    <span class="tui-topbar-right">admin@local</span>
  </header>

  <!-- NAV TABS -->
<nav class="tui-nav">
  {navItems.map((item) => {
    const isActive = currentPath.startsWith(item.href);
    return (
      <a href={item.href} class:list={["tui-nav-item", { "tui-nav-active": isActive }]}>
        <span class="tui-nav-cmd">{item.cmd}</span>
        <span>{item.label}</span>
      </a>
    );
  })}
  <div class="tui-nav-spacer"></div>
  <a href="/admin/logout" class:list={["tui-nav-item", "tui-nav-logout"]} id="logout-btn">
    <span class="tui-nav-cmd">F10</span>
    <span>logout</span>
  </a>
</nav>

  <!-- MAIN -->
  <main class="tui-main">
    <slot />
  </main>

  <!-- STATUSBAR -->
  <footer class="tui-statusbar">
    <span class="tui-status-item">ESC <span class="tui-status-label">back</span></span>
    <span class="tui-status-item">TAB <span class="tui-status-label">next field</span></span>
    <span class="tui-status-item">ENTER <span class="tui-status-label">confirm</span></span>
    <span class="tui-statusbar-right">PORTFOLIO CMS v1.0</span>
  </footer>

</body>
<script>
  const token = sessionStorage.getItem("token");
  if (!token) window.location.href = "/login";

  document.getElementById("logout-btn").addEventListener("click", () => {
    sessionStorage.removeItem("token");
    window.location.href = "/login";
  });
</script>
</html>
